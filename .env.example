# CROO CAP endpoints (defaults shown)
CROO_API_URL=https://api.croo.network
CROO_WS_URL=wss://api.croo.network/ws

# SDK-Key from the CROO Dashboard for THIS agent (shown once on registration)
# Each running agent process (Contractor / each specialist / requester) uses its own key.
CROO_SDK_KEY=croo_sk_xxx

# Base network RPC (USDC settlement chain). Gas is sponsored by CROO.
BASE_RPC_URL=https://mainnet.base.org

# --- Requester / orchestrator targets ---
# Default specialist serviceId for the standalone requester demo.
CROO_TARGET_SERVICE_ID=

# Comma-separated serviceIds the orchestrator is allowed to hire.
# Populate from registry.ts entries or partner agents recruited in Discord.
CONTRACTOR_REGISTRY_SERVICE_IDS=

# Spend guardrails (USDC) so the orchestrator never overspends.
MAX_USDC_PER_ORDER=2.00
MAX_USDC_PER_JOB=10.00
