{
  "name": "croo-contractor-agent",
  "version": "0.1.0",
  "description": "CROO Contractor — CAP-native A2A orchestrator by @thesithunyein. Hires, verifies, and composes specialist agents on the CROO Agent Store.",
  "license": "MIT",
  "type": "commonjs",
  "engines": {
    "node": ">=18"
  },
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "provider": "cross-env ENV_FILE=.env.contractor ts-node src/provider.ts",
    "orchestrate": "cross-env ENV_FILE=.env.contractor ts-node src/orchestrator.ts",
    "fanout": "cross-env ENV_FILE=.env.contractor ts-node src/fanout.ts",
    "demo": "cross-env ENV_FILE=.env.contractor ts-node src/demo.ts",
    "requester": "cross-env ENV_FILE=.env.requester ts-node src/requester.ts",
    "specialist:solana": "cross-env ENV_FILE=.env.solana SPECIALIST=solana-tx-doctor ts-node src/specialists/run.ts",
    "specialist:summarizer": "cross-env ENV_FILE=.env.summarizer SPECIALIST=summarizer ts-node src/specialists/run.ts"
  },
  "dependencies": {
    "@croo-network/sdk": "^0.1.0",
    "@types/node": "^20.14.0",
    "cross-env": "^7.0.3",
    "dotenv": "^16.4.5",
    "ts-node": "^10.9.2",
    "typescript": "5.9.3"
  },
  "devDependencies": {}
}
